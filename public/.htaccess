AddDefaultCharset UTF-8

AddType 'application/javascript; charset=UTF-8' .js

<IfModule mod_rewrite.c>
RewriteEngine On

############################################
# 1. REDIRECT SUBDOMAIN -> DOMAIN CHÍNH
############################################
RewriteCond %{HTTP_HOST} ^(www\.)?xanhworld\.haiphongtech\.vn$ [NC]
RewriteRule ^(.*)$ https://xanhworld.vn/$1 [L,R=301]

############################################
# 2. FORCE HTTPS
############################################
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

############################################
# 3. WWW → NON-WWW
############################################
RewriteCond %{HTTP_HOST} ^www\.xanhworld\.vn$ [NC]
RewriteRule ^ https://xanhworld.vn%{REQUEST_URI} [R=301,L]

############################################
# 4. BẢO MẬT
############################################

# CHỈ chặn nếu KHÔNG PHẢI Googlebot, Bingbot, Applebot, Yandex
RewriteCond %{HTTP_USER_AGENT} !(googlebot|bingbot|yandex|applebot) [NC]
RewriteCond %{HTTP_USER_AGENT} (wget|curl|ApacheBench) [NC]
RewriteRule ^ - [F,L]

# Tắt MultiViews
<IfModule mod_negotiation.c>
Options -MultiViews -Indexes
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(webp)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

############################################
# 5. DỌN ĐƯỜNG DẪN
############################################
# Gộp nhiều dấu //
RewriteCond %{REQUEST_URI} ^(.*)//+(.*)$
RewriteRule ^ %1/%2 [R=301,L]

# Remove trailing slash
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [R=301,L]

# Redirect index.php -> /
RewriteCond %{THE_REQUEST} \s/index\.php[?\s] [NC]
RewriteRule ^index\.php$ https://xanhworld.vn/ [R=301,L]

# Redirect index.php/something
RewriteCond %{THE_REQUEST} \s/index\.php/([^\s?]*) [NC]
RewriteRule ^index\.php/(.*)$ https://xanhworld.vn/%1 [R=301,L]

##############################################
# 6. LITESPEED CACHE – FULL OPTIMIZED CONFIG #
##############################################

# <IfModule LiteSpeed>

